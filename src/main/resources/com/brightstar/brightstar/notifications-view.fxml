<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.brightstar.brightstar.NotificationController"
        style="-fx-background-color:#c8900a;">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" prefHeight="68.0">
        <padding><Insets top="12" right="28" bottom="8" left="24"/></padding>

        <VBox HBox.hgrow="ALWAYS">
            <Label text="BrightStart Preschool SIMS"
                   style="-fx-text-fill:white;-fx-font-size:26px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
            <Label text="Dashboard  >  Notifications  >  Send Notifications"
                   style="-fx-text-fill:rgba(255,255,255,0.72);-fx-font-size:11px;-fx-font-family:'Georgia';"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="16">
            <StackPane prefWidth="44" prefHeight="44" maxWidth="44" maxHeight="44"
                       style="-fx-background-color:#e8e8e8;-fx-background-radius:50;">
                <Label fx:id="avatarLabel" text="A"
                       style="-fx-text-fill:#555;-fx-font-size:16px;-fx-font-weight:bold;"/>
            </StackPane>
        </HBox>
    </HBox>

    <!-- ── TOOLBAR ── -->
    <HBox spacing="10.0">
        <padding><Insets top="0" right="24" bottom="16" left="24"/></padding>
        <Button text="Search Notifications" mnemonicParsing="false"
                style="-fx-background-color:white;-fx-background-radius:3;-fx-border-color:#ccc;
                       -fx-border-radius:3;-fx-font-size:12px;-fx-font-family:'Georgia';
                       -fx-cursor:hand;-fx-padding:5 14 5 14;"/>
        <ComboBox value="Filter By Date" prefHeight="30"
                  style="-fx-background-color:white;-fx-background-radius:3;
                         -fx-border-color:#ccc;-fx-border-radius:3;-fx-font-size:12px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back" mnemonicParsing="false"
                onAction="#handleBack"
                style="-fx-background-color:white;-fx-background-radius:3;-fx-border-color:#ccc;
                       -fx-border-radius:3;-fx-font-size:12px;-fx-font-family:'Georgia';
                       -fx-cursor:hand;-fx-padding:5 14 5 14;"/>
    </HBox>

    <!-- ── NOTIFICATION HISTORY (on amber) ── -->
    <VBox VBox.vgrow="NEVER">
        <padding><Insets top="0" right="24" bottom="16" left="24"/></padding>
        <spacing>0</spacing>

        <Label text="Notification History"
               style="-fx-text-fill:white;-fx-font-size:18px;-fx-font-weight:bold;
                      -fx-font-family:'Georgia';-fx-padding:0 0 10 0;"/>

        <!-- Column headers -->
        <HBox prefHeight="36.0">
            <Label text="Recipient" prefWidth="160"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
            <Label text="Subject" prefWidth="200"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
            <Label text="Status" prefWidth="120"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
        </HBox>

        <!-- Dynamic rows from DB -->
        <VBox fx:id="historyTable"/>

    </VBox>

    <!-- ── NEW NOTIFICATION FORM ── -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color:white;-fx-background-radius:0;">
        <padding><Insets top="24" right="28" bottom="28" left="24"/></padding>
        <spacing>16</spacing>

        <Label text="New Notification"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>

        <!-- Recipient -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <Label text="Recipient:" prefWidth="80"
                   style="-fx-font-size:13px;-fx-font-family:'Georgia';-fx-text-fill:#333;"/>
            <ComboBox fx:id="recipientCombo"
                      prefWidth="160" prefHeight="32"
                      style="-fx-background-color:#c8900a;-fx-background-radius:4;
                             -fx-text-fill:white;-fx-font-size:12px;-fx-font-family:'Georgia';"/>
        </HBox>

        <!-- Subject -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <Label text="Subject:" prefWidth="80"
                   style="-fx-font-size:13px;-fx-font-family:'Georgia';-fx-text-fill:#333;"/>
            <ComboBox fx:id="subjectCombo"
                      prefWidth="200" prefHeight="32"
                      style="-fx-background-color:#c8900a;-fx-background-radius:4;
                             -fx-text-fill:white;-fx-font-size:12px;-fx-font-family:'Georgia';"/>
        </HBox>

        <!-- Message -->
        <HBox alignment="TOP_LEFT" spacing="16.0">
            <Label text="Message:" prefWidth="80"
                   style="-fx-font-size:13px;-fx-font-family:'Georgia';-fx-text-fill:#333;-fx-padding:6 0 0 0;"/>
            <TextArea fx:id="messageArea"
                      prefWidth="360" prefHeight="80"
                      wrapText="true"
                      promptText="Type your message here..."
                      style="-fx-background-color:#ebebeb;-fx-background-radius:4;
                             -fx-border-color:#d5d5d5;-fx-border-radius:4;-fx-border-width:1;
                             -fx-font-size:13px;-fx-font-family:'Georgia';
                             -fx-text-fill:#333;-fx-prompt-text-fill:#aaa;"/>
        </HBox>

        <!-- Feedback label -->
        <Label fx:id="feedbackLabel"
               style="-fx-font-size:12px;-fx-font-family:'Georgia';"/>

        <Region prefHeight="4"/>

        <!-- Send Button -->
        <Button text="Send Notification" mnemonicParsing="false"
                onAction="#handleSend"
                prefHeight="38"
                style="-fx-background-color:#c8900a;-fx-background-radius:5;
                       -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                       -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:8 20 8 20;"/>

    </VBox>

</VBox>