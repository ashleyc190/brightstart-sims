<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.brightstar.brightstar.DashboardController"
        style="-fx-background-color:#c8900a;">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" prefHeight="72.0">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>

        <VBox HBox.hgrow="ALWAYS">
            <Label text="BrightStart Preschool SIMS"
                   style="-fx-text-fill:white;-fx-font-size:28px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
            <Label text="Dashboard"
                   style="-fx-text-fill:rgba(255,255,255,0.70);-fx-font-size:11px;-fx-font-family:'Georgia';"/>
        </VBox>

        <HBox spacing="4.0" alignment="CENTER_LEFT">
            <!-- Add this button -->
            <Button text="+ New Student" mnemonicParsing="false"
                    onAction="#handleNewStudent"
                    style="-fx-background-color:#1a1a1a;-fx-background-radius:5;
                   -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                   -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:9 20 9 20;"/>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="16.0">
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="dateLabel" text="28 April 2026"
                       style="-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-font-family:'Georgia';"/>
                <Label fx:id="greetingLabel" text="Good morning"
                       style="-fx-text-fill:rgba(255,255,255,0.72);-fx-font-size:11px;-fx-font-family:'Georgia';"/>
            </VBox>
            <StackPane prefWidth="44" prefHeight="44" maxWidth="44" maxHeight="44"
                       style="-fx-background-color:#e8e8e8;-fx-background-radius:50;">
                <Label text="A"
                       style="-fx-text-fill:#555;-fx-font-size:16px;-fx-font-weight:bold;"/>
            </StackPane>
        </HBox>
    </HBox>

    <!-- ── DIVIDER ── -->
    <Region prefHeight="2"
            style="-fx-background-color:rgba(0,0,0,0.15);"/>

    <!-- ── MAIN CONTENT ── -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color:#efefed;">
        <padding><Insets top="36" right="36" bottom="36" left="36"/></padding>
        <spacing>28</spacing>

        <!-- Welcome banner -->
        <VBox spacing="4.0">
            <Label text="Welcome back 👋"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
            <Label text="What would you like to manage today?"
                   style="-fx-font-size:13px;-fx-font-family:'Georgia';-fx-text-fill:#888;"/>
        </VBox>

        <!-- ── NAV CARDS GRID ── -->
        <HBox spacing="20.0">

            <!-- Attendance -->
            <VBox spacing="16.0" HBox.hgrow="ALWAYS" prefHeight="190.0"
                  style="-fx-background-color:white;-fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,3);
                         -fx-cursor:hand;">
                <padding><Insets top="28" right="24" bottom="28" left="24"/></padding>

                <!-- Icon circle -->
                <StackPane prefWidth="52" prefHeight="52" maxWidth="52" maxHeight="52"
                           style="-fx-background-color:rgba(200,144,10,0.12);-fx-background-radius:50;">
                    <Label text="📋"
                           style="-fx-font-size:22px;"/>
                </StackPane>

                <VBox spacing="4.0">
                    <Label text="Attendance"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
                    <Label text="Record and track daily attendance for each class"
                           wrapText="true"
                           style="-fx-font-size:12px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Open  →" mnemonicParsing="false"
                        onAction="#handleAttendance"
                        style="-fx-background-color:#c8900a;-fx-background-radius:5;
                               -fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;
                               -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
            </VBox>

            <!-- Payments -->
            <VBox spacing="16.0" HBox.hgrow="ALWAYS" prefHeight="190.0"
                  style="-fx-background-color:white;-fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,3);
                         -fx-cursor:hand;">
                <padding><Insets top="28" right="24" bottom="28" left="24"/></padding>

                <StackPane prefWidth="52" prefHeight="52" maxWidth="52" maxHeight="52"
                           style="-fx-background-color:rgba(200,144,10,0.12);-fx-background-radius:50;">
                    <Label text="💳"
                           style="-fx-font-size:22px;"/>
                </StackPane>

                <VBox spacing="4.0">
                    <Label text="Payments"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
                    <Label text="Record fee payments and view outstanding balances"
                           wrapText="true"
                           style="-fx-font-size:12px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Open  →" mnemonicParsing="false"

                        style="-fx-background-color:#c8900a;-fx-background-radius:5;
                               -fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;
                               -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
            </VBox>

            <!-- Reports -->
            <VBox spacing="16.0" HBox.hgrow="ALWAYS" prefHeight="190.0"
                  style="-fx-background-color:white;-fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,3);
                         -fx-cursor:hand;">
                <padding><Insets top="28" right="24" bottom="28" left="24"/></padding>

                <StackPane prefWidth="52" prefHeight="52" maxWidth="52" maxHeight="52"
                           style="-fx-background-color:rgba(200,144,10,0.12);-fx-background-radius:50;">
                    <Label text="📊"
                           style="-fx-font-size:22px;"/>
                </StackPane>

                <VBox spacing="4.0">
                    <Label text="Reports"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
                    <Label text="View attendance, fee, and student summary reports"
                           wrapText="true"
                           style="-fx-font-size:12px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Open  →" mnemonicParsing="false"

                        style="-fx-background-color:#c8900a;-fx-background-radius:5;
                               -fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;
                               -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
            </VBox>

            <!-- Notifications -->
            <VBox spacing="16.0" HBox.hgrow="ALWAYS" prefHeight="190.0"
                  style="-fx-background-color:white;-fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,3);
                         -fx-cursor:hand;">
                <padding><Insets top="28" right="24" bottom="28" left="24"/></padding>

                <StackPane prefWidth="52" prefHeight="52" maxWidth="52" maxHeight="52"
                           style="-fx-background-color:rgba(200,144,10,0.12);-fx-background-radius:50;">
                    <Label text="🔔"
                           style="-fx-font-size:22px;"/>
                </StackPane>

                <VBox spacing="4.0">
                    <Label text="Notifications"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
                    <Label text="Send messages to parents and teachers"
                           wrapText="true"
                           style="-fx-font-size:12px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Open  →" mnemonicParsing="false"

                        style="-fx-background-color:#c8900a;-fx-background-radius:5;
                               -fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;
                               -fx-font-family:'Georgia';-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
            </VBox>

        </HBox>

        <!-- ── QUICK STATS ROW ── -->
        <HBox spacing="20.0">

            <HBox spacing="14.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-background-radius:8;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                <Label text="👤" style="-fx-font-size:20px;"/>
                <VBox spacing="2.0">
                    <Label text="Total Students"
                           style="-fx-font-size:11px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                    <Label fx:id="statStudents" text="60"
                           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#1a1a1a;"/>
                </VBox>
            </HBox>

            <HBox spacing="14.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-background-radius:8;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                <Label text="✅" style="-fx-font-size:20px;"/>
                <VBox spacing="2.0">
                    <Label text="Present Today"
                           style="-fx-font-size:11px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                    <Label fx:id="statPresent" text="54"
                           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#4caf50;"/>
                </VBox>
            </HBox>

            <HBox spacing="14.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-background-radius:8;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                <Label text="💰" style="-fx-font-size:20px;"/>
                <VBox spacing="2.0">
                    <Label text="Outstanding Fees"
                           style="-fx-font-size:11px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                    <Label fx:id="statFees" text="R 5 000"
                           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#e57373;"/>
                </VBox>
            </HBox>

            <HBox spacing="14.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-background-radius:8;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                <Label text="🔔" style="-fx-font-size:20px;"/>
                <VBox spacing="2.0">
                    <Label text="Pending Notifications"
                           style="-fx-font-size:11px;-fx-font-family:'Georgia';-fx-text-fill:#999;"/>
                    <Label fx:id="statNotifications" text="3"
                           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-font-family:'Georgia';-fx-text-fill:#ffb74d;"/>
                </VBox>
            </HBox>

        </HBox>

    </VBox>

    <!-- ── FOOTER ── -->
    <HBox alignment="CENTER_LEFT" prefHeight="40.0"
          style="-fx-background-color:#1a1a1a;">
        <padding><Insets left="28" right="28"/></padding>
        <Label text="BrightStart Preschool SIMS  ·  v1.0"
               style="-fx-text-fill:#666;-fx-font-size:11px;-fx-font-family:'Georgia';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Logged in as Administrator"
               style="-fx-text-fill:#666;-fx-font-size:11px;-fx-font-family:'Georgia';"/>
    </HBox>

</VBox>